# ══════════════════════════════════════════════
# Copie este arquivo para ".env" (sem o ".example") e preencha os valores.
# NUNCA compartilhe o .env nem suba ele pro GitHub.
# ══════════════════════════════════════════════

# Sua chave da API da Anthropic (Claude)
# Pegue em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-sua-chave-aqui

# Chave de acesso ao painel admin (/admin.html?key=...)
# Invente uma senha forte e longa, só você vai usar isso.
ADMIN_KEY=escolha-uma-chave-forte-aqui

# Secret do webhook da Eduzz — você recebe isso DEPOIS de criar a
# configuração do webhook no painel da Eduzz (Developer Hub).
# Enquanto não configurar, pode deixar em branco — mas configure assim
# que possível, pois sem isso qualquer pessoa poderia chamar seu endpoint
# de webhook fingindo ser a Eduzz.
EDUZZ_WEBHOOK_SECRET=

# Porta do servidor (o Railway define isso automaticamente, pode deixar)
PORT=3000

# Ambiente (deixe "production" quando estiver no Railway/hospedagem real;
# em desenvolvimento local pode deixar vazio ou "development")
NODE_ENV=production
